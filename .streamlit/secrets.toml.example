# Contoh file secrets untuk menjalankan Streamlit secara lokal.
# Salin file ini menjadi `.streamlit/secrets.toml` lalu isi URL API kamu.
# JANGAN commit secrets.toml (sudah ada di .gitignore).
#
# Di Streamlit Community Cloud, isi nilai yang sama lewat dashboard:
# App → Settings → Secrets.

API_URL = "https://tokopedia-api-production.up.railway.app"
